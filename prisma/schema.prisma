generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  privyWalletId String   @unique
  address       String   @unique
  createdAt     DateTime @default(now())
}

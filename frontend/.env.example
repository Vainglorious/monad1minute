# --- Privy (server wallet creation) ---
# Create an app at https://dashboard.privy.io and copy these.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# P-256 authorization private key — your backend becomes the owner of created wallets.
# Generate in the Privy dashboard (Wallet infrastructure -> Authorization keys).
PRIVY_AUTHORIZATION_KEY=
# Optional: SDK request timeout in ms (default 25000). Raise if you see timeouts.
PRIVY_TIMEOUT_MS=25000

# --- Database (Postgres: Supabase / Neon / local) ---
# Supabase: use the CONNECTION POOLER (Supavisor) strings — the direct
# db.<ref>.supabase.co host is IPv6-only and fails on most networks.
# Dashboard -> Connect -> ORMs/Prisma gives you both of these:
#   DATABASE_URL = transaction pooler, port 6543, with ?pgbouncer=true
#   DIRECT_URL   = session pooler,     port 5432  (used for migrations / db push)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Session signing ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- Monad network (mainnet) ---
MONAD_RPC=https://rpc.monad.xyz
MONAD_CHAIN_ID=143

# --- Signup funding (auto-transfer to each new wallet) ---
# The deployer signs a native MON transfer to each newly created wallet.
# WARNING: on mainnet this sends REAL funds to anyone who signs up — add
# anti-abuse (rate limit / captcha / allowlist) before any public launch.
DEPLOYER_PRIVATE_KEY=
# Optional: if set, must match the address derived from DEPLOYER_PRIVATE_KEY.
DEPLOYER_ADDRESS=
# Amount of MON sent to each new wallet at signup.
# Must cover one bet (betAmount, currently 0.2 MON) plus gas.
SIGNUP_FUNDING_MON=0.3

# --- PriceBetGame contract ---
# The live 1-minute betting contract on Monad mainnet (per-bucket multipliers).
# NOTE: must match the contract the operator runs. The old 0x0f6Cce… contract
# predates getBucketMultipliers and will revert /api/round reads.
PRICEBETGAME_ADDRESS=0x7639Cc0fD49E8D574a75c71874C7a37665F751c0

# --- Operator ---
# The standalone operator-bot/ is the PRIMARY operator (run it on an always-on
# machine: `cd operator-bot && npm start`). It settles rounds from Coinbase
# 1-minute candles, matching the chart's BASE line.
# /api/operator/tick remains as a MANUAL self-heal fallback (no cron): trigger
# it with `curl -H "Authorization: Bearer $CRON_SECRET" <app>/api/operator/tick`
# if the bot is down and a round is stuck. Run ONE operator at a time.
# Key of the contract's `operator` address — signs startRound/resolveRound.
OPERATOR_PRIVATE_KEY=
# Shared secret gating the tick endpoint. Generate with: openssl rand -hex 32
CRON_SECRET=
# Optional override for the Coinbase REST host (settlement + chart base price).
# COINBASE_REST_HOST=https://api.exchange.coinbase.com

# --- Live price ticker (BTC/USD) ---
# Optional. Order tried: coinbase -> binanceus -> binance. PRICE_SOURCE forces one.
# PRICE_SOURCE=coinbase
# PRICE_ASSET=BTC

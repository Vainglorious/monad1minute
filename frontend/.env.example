# --- Privy (server wallet creation) ---
# Create an app at https://dashboard.privy.io and copy these.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# P-256 authorization private key — your backend becomes the owner of created wallets.
# Generate in the Privy dashboard (Wallet infrastructure -> Authorization keys).
PRIVY_AUTHORIZATION_KEY=

# --- Database (Postgres: Supabase / Neon / local) ---
# Supabase: use the CONNECTION POOLER (Supavisor) strings — the direct
# db.<ref>.supabase.co host is IPv6-only and fails on most networks.
# Dashboard -> Connect -> ORMs/Prisma gives you both of these:
#   DATABASE_URL = transaction pooler, port 6543, with ?pgbouncer=true
#   DIRECT_URL   = session pooler,     port 5432  (used for migrations / db push)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Session signing ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- Monad testnet ---
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
